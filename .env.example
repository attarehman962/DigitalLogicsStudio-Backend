# Copy this file to .env for local development.
# On Vercel, set these as Environment Variables in the project dashboard.

PORT=5000

# Set to "production" on Vercel, "development" locally
NODE_ENV=development

# The deployed frontend URL (no trailing slash).
# Must match exactly what the browser sends as the Origin header.
CLIENT_URL=https://circuits.quantumlogicslimited.com

MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/digitallogicsstudio?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_DAYS=7
